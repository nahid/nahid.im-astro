---
// The nameplate: kicker → THE ALIEN DISPATCH → dateline bar.
// The sitewide dateline is Bengali (site is Bengali-first, §3 4b).
import { SITE } from '../consts';
import { formatDate } from '../utils/format';
import Ufo from './Ufo.astro';

const today = formatDate(new Date(), 'en');
---

<header class="masthead">
	<Ufo class="masthead__ufo" />

	<p class="masthead__kicker">{SITE.kicker}</p>
	<a class="masthead__nameplate" href="/" aria-label={`${SITE.masthead} — home`}>
		{SITE.masthead}
	</a>
	<div class="masthead__dateline">
		<span class="rule" aria-hidden="true"></span>
		<time datetime={new Date().toISOString().slice(0, 10)}>{today}</time>
		<span class="rule" aria-hidden="true"></span>
	</div>
</header>

<style>
	.masthead {
		position: relative;
		text-align: center;
		/* Extra vertical room so the saucer behind the nameplate reads as a drawing
		   rather than as a couple of stray arcs clipped at the edges. */
		padding-top: var(--sp-6);
		/* The saucer is drawn oversized and bleeds past the nameplate; clip it to
		   the masthead so it can never push the sheet sideways. */
		overflow: hidden;
	}
	/* Engraving in the right margin, bleeding off the sheet edge — the way a
	   letterpress paper would run an ornament.
	   Deliberately NOT centred behind the nameplate: the nameplate is the
	   heaviest type on the site, so a drawing underneath it is simply occluded —
	   all that escapes is a few stray strokes, which read as a printing smudge
	   rather than a saucer. Off to the side it stays legible as an object and the
	   nameplate keeps its full contrast. */
	:global(.masthead__ufo) {
		position: absolute;
		top: 50%;
		right: -2rem;
		z-index: 0;
		/* Sized off the masthead's own height: the drawing is 4:2.5, so sizing by
		   viewport width overshot the header and the clip sheared off its dome. */
		height: 116%;
		width: auto;
		transform: translateY(-50%);
		color: var(--ink);
		opacity: 0.13;
		pointer-events: none;
	}
	/* Below this the nameplate spans the full sheet, so there is no side margin to
	   run the ornament in. Shrink it and anchor it to the top-right corner instead,
	   where it clears the nameplate's cap line and only the kicker's tail passes
	   under it. */
	@media (max-width: 48rem) {
		:global(.masthead__ufo) {
			top: 0;
			right: -1.5rem;
			height: auto;
			width: 42%;
			transform: none;
			opacity: 0.11;
		}
	}
	/* Everything else rides above the drawing. */
	.masthead__kicker,
	.masthead__nameplate,
	.masthead__dateline {
		position: relative;
		z-index: 1;
	}
	.masthead__kicker {
		margin: 0 0 var(--sp-2);
		font-family: var(--font-display);
		font-size: var(--fs-label);
		text-transform: uppercase;
		letter-spacing: 0.32em;
		color: var(--faded);
	}
	.masthead__nameplate {
		display: block;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: var(--fs-masthead);
		line-height: 0.95;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		text-decoration: none;
		color: var(--ink);
		overflow-wrap: break-word;
	}
	.masthead__nameplate:hover {
		color: var(--ink);
	}
	.masthead__dateline {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: var(--sp-4);
		margin-top: var(--sp-3);
		font-size: var(--fs-meta);
		color: var(--faded);
	}
	.masthead__dateline .rule {
		border-top: 3px double var(--rule);
		height: 3px;
	}
	/* Small phones: the wide kicker tracking is the likeliest source of
	   horizontal overflow — ease it and let the string wrap. */
	@media (max-width: 24rem) {
		.masthead__kicker {
			letter-spacing: 0.2em;
			overflow-wrap: break-word;
		}
	}
</style>
