---
// "Subscribe to the Dispatch" coupon box, dashed border. No email list is
// run for this static site — the coupon points at the RSS feed instead,
// which needs no backend and no client JS.
import { t } from '../utils/strings';

const lang = 'en' as const;
---

<div class="coupon">
	<p class="coupon__title" lang={lang}>{t('subscribe', lang)}</p>
	<p class="coupon__body" lang={lang}>{t('subscribeRssBody', lang)}</p>
	<a class="coupon__btn" href="/rss.xml" lang={lang}>{t('subscribeCta', lang)}</a>
</div>

<style>
	.coupon {
		border: 2px dashed var(--rule);
		padding: var(--sp-4);
	}
	.coupon__title {
		margin: 0 0 var(--sp-2);
		font-family: var(--font-display);
		font-weight: 700;
		font-size: var(--fs-h3);
	}
	.coupon__body {
		margin: 0 0 var(--sp-3);
		color: var(--faded);
	}
	.coupon__btn {
		display: inline-block;
		padding: var(--sp-2) var(--sp-4);
		font-family: var(--font-display);
		font-weight: 700;
		font-size: var(--fs-body);
		color: var(--paper);
		background: var(--ink);
		border: var(--rule-thin);
		text-decoration: none;
	}
	.coupon__btn:hover {
		background: var(--accent);
		border-color: var(--accent);
	}
</style>
