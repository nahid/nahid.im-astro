---
// Archive pager, styled "← Newer / Older →". Renders nothing if there's one page.
import { t } from '../utils/strings';

interface Props {
	prevUrl?: string;
	nextUrl?: string;
	current: number;
	total: number;
	/** Dominant page language for the labels. */
	lang?: 'bn' | 'en';
}

const { prevUrl, nextUrl, current, total, lang = 'en' } = Astro.props;
---

{
	total > 1 && (
		<nav class="pager" aria-label="Pagination">
			<span class="pager__end">
				{prevUrl ? (
					<a href={prevUrl} rel="prev">
						← {t('newer', lang)}
					</a>
				) : (
					<span class="pager__disabled">← {t('newer', lang)}</span>
				)}
			</span>
			<span class="pager__count meta">
				{current} / {total}
			</span>
			<span class="pager__end pager__end--right">
				{nextUrl ? (
					<a href={nextUrl} rel="next">
						{t('older', lang)} →
					</a>
				) : (
					<span class="pager__disabled">{t('older', lang)} →</span>
				)}
			</span>
		</nav>
	)
}

<style>
	.pager {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: var(--sp-4);
		margin-top: var(--sp-6);
		padding-top: var(--sp-3);
		border-top: var(--rule-thin);
		font-family: var(--font-display);
		font-size: var(--fs-label);
		text-transform: uppercase;
		letter-spacing: var(--letterspace-label);
	}
	.pager__end--right {
		text-align: right;
	}
	.pager__disabled {
		color: var(--faded);
		opacity: 0.5;
	}
	.pager__count {
		font-family: var(--font-mono);
		letter-spacing: 0;
		text-transform: none;
	}
</style>
