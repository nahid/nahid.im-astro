---
// Colophon footer: double rule, byline, copyright, feed link.
import { SITE } from '../consts';

const year = 2026; // build-time stamp
---

<footer class="footer">
	<hr class="rule-double" />
	<div class="footer__row">
		<p class="footer__mast">{SITE.masthead}</p>
		<p class="footer__meta meta">
			© {SITE.established}–{year} {SITE.author} ·
			<a href="/rss.xml">RSS</a>
		</p>
	</div>
	<p class="footer__colophon meta">
		Set in Special Elite, Cutive Mono &amp; Noto Serif Bengali. Printed on paper that
		doesn&rsquo;t exist.
	</p>
</footer>

<style>
	.footer {
		margin-top: var(--sp-7);
	}
	.footer__row {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: baseline;
		gap: var(--sp-3);
	}
	.footer__mast {
		margin: 0;
		font-family: var(--font-display);
		text-transform: uppercase;
		letter-spacing: var(--letterspace-label);
		font-size: var(--fs-label);
	}
	.footer__meta {
		margin: 0;
	}
	.footer__colophon {
		margin: var(--sp-2) 0 0;
		font-style: italic;
	}
</style>
