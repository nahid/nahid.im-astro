---
// Social links as a ruled row of typewriter labels (no icon fonts / no JS).
import { SOCIALS } from '../consts';
---

<ul class="social">
	{
		SOCIALS.map((s) => (
			<li class="social__item">
				<a class="social__link" href={s.href} rel="me noopener" target="_blank">
					{s.label}
				</a>
			</li>
		))
	}
</ul>

<style>
	.social {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		gap: var(--sp-2) var(--sp-4);
		list-style: none;
		margin: 0 0 var(--sp-6);
		padding: 0;
		text-align: center;
	}
	.social__item {
		display: flex;
		align-items: center;
		gap: var(--sp-4);
	}
	.social__item:not(:last-child)::after {
		content: '\2022'; /* middle dot, typewriter-style separator */
		color: var(--faded);
	}
	.social__link {
		font-family: var(--font-display);
		font-size: var(--fs-label);
		text-transform: uppercase;
		letter-spacing: var(--letterspace-label);
		text-decoration: none;
		border-bottom: var(--rule-hair);
		padding-bottom: 2px;
		transition: color 0.15s ease, border-color 0.15s ease;
	}
	.social__link:hover,
	.social__link:focus-visible {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	@media (max-width: 23.4375rem) {
		.social {
			gap: var(--sp-3);
		}
		.social__item {
			gap: var(--sp-3);
		}
	}
</style>
