---
// Home bio block: portrait (grayscale) beside name/role/blurb.
import { BIO } from '../consts';
---

<div class="bio">
	<div class="bio__mount">
		<img class="bio__photo" src={BIO.photo} width="170" height="170" alt={BIO.name} />
	</div>
	<div class="bio__body">
		<p class="bio__name">{BIO.name}</p>
		<p class="bio__role label">{BIO.role}</p>
		<p class="bio__location meta">{BIO.location}</p>
		<div class="bio__blurb">
			{BIO.blurb.map((para) => (
				<p>{para}</p>
			))}
		</div>
	</div>
</div>

<style>
	.bio {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--sp-6);
		align-items: start;
	}
	/* Portrait mount: a clean, modern offset keyline — a thin ink border with a
	   hairline outline floating just outside it (flat, no mat, no shadow). */
	.bio__mount {
		width: max-content;
	}
	.bio__photo {
		display: block;
		width: 170px;
		height: 170px;
		object-fit: cover;
		filter: grayscale(1) contrast(1.05);
		border: var(--rule-thin);
		outline: var(--rule-hair);
		outline-offset: var(--sp-2);
	}
	.bio__name {
		font-family: var(--font-display);
		font-size: var(--fs-h1);
		line-height: 1.1;
		margin: 0 0 var(--sp-2);
	}
	.bio__role {
		margin: 0;
	}
	.bio__location {
		margin: var(--sp-1) 0 var(--sp-3);
		padding-bottom: var(--sp-3);
		border-bottom: 3px double var(--rule);
	}
	.bio__blurb {
		max-width: var(--measure);
	}
	.bio__blurb p {
		margin: 0 0 var(--sp-3);
	}
	.bio__blurb p:last-child {
		margin-bottom: 0;
	}
	/* Drop cap opens the blurb, echoing the article-page treatment (§3). It has to
	   hang off the first paragraph, not the container — ::first-letter on a block
	   with block children never matches. */
	.bio__blurb p:first-child::first-letter {
		float: left;
		font-family: var(--font-display);
		font-size: 2.6em;
		line-height: 0.8;
		padding: 0.05em 0.1em 0 0;
		color: var(--accent);
	}
	/* "Still exploring. Still learning. Still building." — a sign-off, set like one. */
	.bio__blurb p:last-child {
		font-family: var(--font-display);
		color: var(--accent);
		padding-top: var(--sp-3);
		border-top: var(--rule-hair);
	}
	@media (max-width: 34rem) {
		.bio {
			grid-template-columns: 1fr;
			justify-items: center;
			text-align: center;
		}
		.bio__body {
			text-align: left;
			width: 100%;
		}
		.bio__name {
			text-align: center;
		}
	}
</style>
