---
// Home "achievements" list — year in the margin, ruled rows like an almanac.
import { ACHIEVEMENTS } from '../consts';
---

<ul class="ach">
	{
		ACHIEVEMENTS.map((a) => (
			<li class="ach__row">
				<span class="ach__year">{a.year}</span>
				<span class="ach__text">{a.text}</span>
			</li>
		))
	}
</ul>

<style>
	.ach {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: var(--rule-hair);
	}
	.ach__row {
		display: grid;
		grid-template-columns: 4rem 1fr;
		gap: var(--sp-4);
		padding: var(--sp-3) 0;
		border-bottom: var(--rule-hair);
	}
	.ach__year {
		font-family: var(--font-display);
		font-size: var(--fs-label);
		color: var(--accent);
	}
	.ach__text {
		margin: 0;
	}
</style>
