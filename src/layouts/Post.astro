---
// Single-post article layout. Phase 1 delivers the structure; Phase 3 refines
// the Bengali typography (drop-cap equivalent, prev/next copy, dates).
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import Folio from '../components/Folio.astro';
import Masthead from '../components/Masthead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { categoryLabel } from '../utils/categories';
import { formatDate, formatNumber, readingMinutes } from '../utils/format';
import { t } from '../utils/strings';

interface Props {
	post: CollectionEntry<'diaries'>;
	prev?: { slug: string; title: string } | null;
	next?: { slug: string; title: string } | null;
}

const { post, prev, next } = Astro.props;
const { data } = post;
const lang = data.lang;
const minutes = readingMinutes(post.body ?? '', lang);
const ogImage = data.heroImage ? new URL(data.heroImage, Astro.site).href : undefined;
---

<Base title={data.title} description={data.description} lang={lang} ogImage={ogImage}>
	<Folio />
	<Masthead />
	<Nav />

	<article class="post" lang={lang}>
		<p class="post__eyebrow label">
			<a href={`/diaries/category/${data.category}/`}>{categoryLabel(data.category, 'en')}</a>
		</p>
		<h1 class="post__headline">{data.title}</h1>

		<div class="post__byline">
			<span>{t('byline', 'en')}</span>
			<span aria-hidden="true"> · </span>
			<time datetime={data.pubDate.toISOString().slice(0, 10)}>
				{formatDate(data.pubDate, 'en')}
			</time>
			<span aria-hidden="true"> · </span>
			<span>{formatNumber(minutes, 'en')} {t('minRead', 'en')}</span>
		</div>

		{
			data.heroImage && (
				<figure>
					<img src={data.heroImage} alt={data.title} />
				</figure>
			)
		}

		<div class={`prose prose--${lang}`}>
			<slot />
		</div>
	</article>

	{
		(prev || next) && (
			<nav class="post-nav" aria-label="More dispatches">
				<span class="post-nav__end">
					{prev && (
						<a href={`/diaries/${prev.slug}/`}>
							<span class="label">
								{t('prevPost', 'en')}
							</span>
							<span class="post-nav__title">{prev.title}</span>
						</a>
					)}
				</span>
				<span class="post-nav__end post-nav__end--right">
					{next && (
						<a href={`/diaries/${next.slug}/`}>
							<span class="label">
								{t('nextPost', 'en')}
							</span>
							<span class="post-nav__title">{next.title}</span>
						</a>
					)}
				</span>
			</nav>
		)
	}

	<Footer />
</Base>

<style>
	.post {
		max-width: var(--measure);
		margin-inline: auto;
		margin-top: var(--sp-6);
	}
	.post__eyebrow {
		margin: 0 0 var(--sp-2);
	}
	.post__eyebrow a {
		text-decoration: none;
	}
	.post__headline {
		font-size: var(--fs-h1);
		margin: 0 0 var(--sp-3);
	}
	.post__byline {
		font-size: var(--fs-meta);
		color: var(--faded);
		padding-bottom: var(--sp-3);
		border-bottom: 3px double var(--ink);
		margin-bottom: var(--sp-5);
	}

	.prose {
		text-align: justify;
	}
	/* Latin body: Cutive Mono, drop cap on the first paragraph. */
	.prose--en :global(> p:first-of-type::first-letter) {
		float: left;
		font-family: var(--font-display);
		font-size: 3.4em;
		line-height: 0.8;
		padding: 0.05em 0.1em 0 0;
		color: var(--accent);
	}
	/* Bengali: no Latin drop cap; an oxblood first-line treatment instead (§3). */
	.prose--bn :global(> p:first-of-type::first-line) {
		color: var(--accent);
		font-weight: 700;
	}
	.prose--bn {
		/* Bengali hyphenation is poor — never break mid-conjunct. */
		hyphens: none;
		word-break: normal;
	}

	.post-nav {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--sp-4);
		max-width: var(--measure);
		margin: var(--sp-7) auto 0;
		padding-top: var(--sp-4);
		border-top: var(--rule-thin);
	}
	.post-nav__end a {
		text-decoration: none;
		display: block;
	}
	.post-nav__end--right {
		text-align: right;
	}
	.post-nav__title {
		display: block;
		margin-top: var(--sp-1);
	}
	.post-nav__end a:hover .post-nav__title {
		color: var(--accent);
	}
</style>
