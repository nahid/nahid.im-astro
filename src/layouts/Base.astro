---
import '../styles/global.css';
import { SITE, BIO, SOCIALS } from '../consts';

interface Props {
	title?: string;
	description?: string;
	/** Dominant language for <html lang> (§3): post pages pass the post lang. */
	lang?: 'bn' | 'en';
	/** Full OG image URL for this page, if any. Falls back to SITE.ogImage. */
	ogImage?: string;
	/** Present on article pages — switches og:type to "article", emits article:*
	 *  tags and a BlogPosting JSON-LD node. Dates are ISO strings. */
	article?: {
		publishedTime: string;
		modifiedTime?: string;
		author?: string;
	};
	/** Paginated archives thread these so crawlers get rel=prev/next. */
	prevUrl?: string;
	nextUrl?: string;
	/** Keep this page out of the index (404, dev-only pages). */
	noindex?: boolean;
}

const {
	title,
	description = SITE.description,
	lang = 'bn',
	ogImage,
	article,
	prevUrl,
	nextUrl,
	noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.masthead}` : SITE.title;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogLocale = lang === 'bn' ? 'bn_BD' : 'en_US';
const ogType = article ? 'article' : 'website';
const ogImageUrl = new URL(ogImage ?? SITE.ogImage, Astro.site).href;
const homeUrl = new URL('/', Astro.site).href;
const prevHref = prevUrl ? new URL(prevUrl, Astro.site).href : undefined;
const nextHref = nextUrl ? new URL(nextUrl, Astro.site).href : undefined;

// Structured data. A Person + WebSite graph rides every page; article pages add
// a BlogPosting. This is inert data, not client-side script (§ zero-JS rule).
const person = {
	'@type': 'Person',
	name: SITE.author,
	url: homeUrl,
	jobTitle: BIO.role,
	image: new URL(BIO.photo, Astro.site).href,
	sameAs: SOCIALS.map((s) => s.href),
};
const jsonLd: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'WebSite',
			name: SITE.title,
			url: homeUrl,
			description: SITE.description,
			inLanguage: ogLocale.replace('_', '-'),
			publisher: person,
		},
		person,
		...(article
			? [
					{
						'@type': 'BlogPosting',
						headline: title,
						description,
						datePublished: article.publishedTime,
						...(article.modifiedTime && { dateModified: article.modifiedTime }),
						author: { '@type': 'Person', name: article.author ?? SITE.author, url: homeUrl },
						publisher: person,
						image: ogImageUrl,
						mainEntityOfPage: canonical,
						url: canonical,
						inLanguage: ogLocale.replace('_', '-'),
					},
				]
			: []),
	],
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#f2ece0" />
		<!-- Portrait favicons, generated locally by scripts/make-favicons.mjs. -->
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
		<link rel="icon" href="/favicon-192.png" type="image/png" sizes="192x192" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta name="author" content={SITE.author} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<link rel="canonical" href={canonical} />
		{prevHref && <link rel="prev" href={prevHref} />}
		{nextHref && <link rel="next" href={nextHref} />}

		<!-- Bengali body face renders most of every page; preload it. -->
		<link
			rel="preload"
			href="/fonts/noto-serif-bengali-00.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>

		<!-- Open Graph -->
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content={SITE.title} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content={pageTitle} />
		{
			/* Dimensions are only known for the generated default card
			   (scripts/make-og.mjs); hero images vary, so we stay quiet for those. */
			!ogImage && (
				<>
					<meta property="og:image:type" content="image/png" />
					<meta property="og:image:width" content="1200" />
					<meta property="og:image:height" content="630" />
				</>
			)
		}
		{
			article && (
				<>
					<meta property="article:published_time" content={article.publishedTime} />
					{article.modifiedTime && (
						<meta property="article:modified_time" content={article.modifiedTime} />
					)}
					<meta property="article:author" content={article.author ?? SITE.author} />
				</>
			)
		}

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content={SITE.twitterHandle} />
		<meta name="twitter:creator" content={SITE.twitterHandle} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={pageTitle} />

		<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<div class="sheet">
			<slot />
		</div>
	</body>
</html>
