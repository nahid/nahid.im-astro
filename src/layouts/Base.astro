---
import '../styles/global.css';
import { SITE } from '../consts';

interface Props {
	title?: string;
	description?: string;
	/** Dominant language for <html lang> (§3): post pages pass the post lang. */
	lang?: 'bn' | 'en';
	/** Full OG image URL for this page, if any. */
	ogImage?: string;
}

const {
	title,
	description = SITE.description,
	lang = 'bn',
	ogImage,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.masthead}` : SITE.title;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogLocale = lang === 'bn' ? 'bn_BD' : 'en_US';
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />

		<!-- Bengali body face renders most of every page; preload it. -->
		<link
			rel="preload"
			href="/fonts/noto-serif-bengali-00.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>

		<!-- Basic Open Graph; the full <SEO> partial lands in Phase 4. -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:locale" content={ogLocale} />
		{ogImage && <meta property="og:image" content={ogImage} />}
		<meta name="twitter:card" content="summary_large_image" />
	</head>
	<body>
		<div class="sheet">
			<slot />
		</div>
	</body>
</html>
