---
// About page. Long-form copy will grow during migration; Phase 1 ships a
// Bengali-first lede so the typography is reviewable.
import Base from '../layouts/Base.astro';
import Folio from '../components/Folio.astro';
import Masthead from '../components/Masthead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionHead from '../components/SectionHead.astro';
import SocialBar from '../components/SocialBar.astro';
import { BIO } from '../consts';
import { t } from '../utils/strings';
---

<Base title="About" lang="en" description={t('aboutDesc', 'en')}>
	<Folio />
	<Masthead />
	<Nav />

	<main class="about" lang="en">
		
		<div class="about__grid">
			<img class="about__photo" src={BIO.photo} width="220" height="220" alt={BIO.name} />
			<div>
				<h1>{BIO.name}</h1>
				<p class="about__role label">{BIO.role}</p>
				<p>
					I am Nahid Bin Azhar — a software engineer turned entrepreneur, and CTO &amp;
					co-founder of JoulesLabs. Twelve years in the industry now, most of it spent
					building SaaS products, wiring up Shopify integrations, and lately chasing
					large language models and RAG systems further than is probably healthy.
				</p>
				<p>
					I'm one of the more visible PHP contributors coming out of Bangladesh, and I
					spend a fair bit of time mentoring other developers. Most of the writing here
					is in Bengali — engineering, business operations, productivity, and the
					occasional experiment. The aesthetic is old letterpress daily; the writing is
					contemporary.
				</p>
				<p>
					Away from the keyboard, I cook — the same creativity and a dash of curiosity,
					just with more garlic.
				</p>
			</div>
		</div>

		<SectionHead label={t('elsewhere', 'en')} lang="en" />
		<SocialBar />
	</main>

	<Footer />
</Base>

<style>
	.about {
		margin-top: var(--sp-4);
	}
	.about__grid {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--sp-6);
		align-items: start;
		max-width: var(--sheet-max);
	}
	.about__photo {
		width: 220px;
		height: 220px;
		object-fit: cover;
		filter: grayscale(1) contrast(1.05);
		border: var(--rule-thin);
		background: var(--paper-shade);
	}
	.about__role {
		margin-top: 0;
		font-weight: bold;
	}
	.about__grid p {
		text-align: justify;
	}
	@media (max-width: 40rem) {
		.about__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
