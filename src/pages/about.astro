---
// About page. Long-form copy will grow during migration; Phase 1 ships a
// Bengali-first lede so the typography is reviewable.
import Base from '../layouts/Base.astro';
import Folio from '../components/Folio.astro';
import Masthead from '../components/Masthead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionHead from '../components/SectionHead.astro';
import SocialBar from '../components/SocialBar.astro';
import { BIO } from '../consts';
import { t } from '../utils/strings';
---

<Base title="About" lang="en" description={t('aboutDesc', 'en')}>
	<Folio />
	<Masthead />
	<Nav />

	<main id="main" class="about" lang="en">
		<SectionHead label={t('about', 'en')} lang="en" />

		<div class="about__grid">
			<img class="about__photo" src={BIO.photo} width="220" height="220" alt={BIO.name} />
			<div class="about__body">
				<h1>{BIO.name}</h1>
				<p class="about__role label">{BIO.role}</p>

				<p class="about__lede">
					Hi, I&rsquo;m <strong>Nahid Bin Azhar</strong> (also known as{' '}
					<strong>Mehedi Hasan Nahid</strong>) — a CTO, co-founder, software engineer,
					and open-source contributor from Bangladesh.
				</p>
				<p>
					For more than 12 years, I&rsquo;ve been building software that solves
					real-world problems. My career began as a software engineer, where I had the
					opportunity to work across a wide range of technologies, architectures, and
					industries. Over time, my focus shifted beyond writing code to building
					products, leading teams, and creating experiences that people genuinely enjoy
					using.
				</p>
				<p>
					Today, I&rsquo;m the <strong>CTO &amp; Co-founder of JoulesLabs</strong>, where
					we&rsquo;re building SaaS products with a strong focus on Shopify and
					AI-powered experiences. I enjoy turning complex technical challenges into
					simple, reliable solutions — whether that means designing scalable backend
					systems, integrating with external platforms, or applying large language models
					and retrieval-augmented generation (RAG) to build intelligent, context-aware
					applications. My passion lies in creating products that customers love while
					improving the developer experience for the teams building them.
				</p>
				<p>
					Throughout my career, I&rsquo;ve worked with technologies including Laravel,
					TypeScript, Go, Node.js, Docker, Kubernetes, Redis, PostgreSQL, MySQL, and
					modern cloud infrastructure. While I enjoy exploring new tools, I believe great
					software is built on solid engineering principles rather than any particular
					technology stack.
				</p>
				<p>
					Open source has played a defining role in my journey. I believe the best way to
					learn is by building, sharing, and collaborating with others. I&rsquo;m proud to
					be recognized as one of the top PHP open-source contributors in Bangladesh, and
					I continue to contribute to projects that help developers build better
					software.
				</p>
				<p>
					In 2019, I was honored to receive the{' '}
					<strong>BASIS National ICT Award</strong> — a milestone that reinforced my
					commitment to creating technology with real-world impact.
				</p>
				<p>
					Outside of work, I enjoy mentoring developers, exploring emerging technologies,
					and continuously learning. I also love cooking — a hobby that reminds me a lot
					of software engineering: both reward curiosity, experimentation, and careful
					attention to detail.
				</p>
				<p>
					Whether I&rsquo;m architecting distributed systems, contributing to open
					source, or building the next product at JoulesLabs, my goal remains the same: to
					create technology that people genuinely enjoy using, and that makes
					developers&rsquo; lives a little easier.
				</p>
			</div>
		</div>

		<SectionHead label={t('elsewhere', 'en')} lang="en" />
		<SocialBar />
	</main>

	<Footer />
</Base>

<style>
	.about {
		margin-top: var(--sp-4);
	}
	.about__grid {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--sp-6);
		align-items: start;
		max-width: var(--sheet-max);
	}
	.about__photo {
		width: 220px;
		height: 220px;
		object-fit: cover;
		filter: grayscale(1) contrast(1.05);
		border: var(--rule-thin);
		background: var(--paper-shade);
	}
	/* Cap the text column. Left at 1fr it runs ~110 characters on a wide screen,
	   well past a readable measure for a page this long. */
	.about__body {
		max-width: 42rem;
	}
	.about__role {
		margin-top: 0;
		padding-bottom: var(--sp-3);
		border-bottom: 3px double var(--rule);
		font-weight: bold;
	}
	.about__grid p {
		text-align: justify;
	}
	/* The lede carries the drop cap, echoing the bio and the article pages (§3). */
	.about__lede::first-letter {
		float: left;
		font-family: var(--font-display);
		font-size: 2.6em;
		line-height: 0.8;
		padding: 0.05em 0.1em 0 0;
		color: var(--accent);
	}
	.about__body strong {
		font-weight: 700;
	}
	@media (max-width: 40rem) {
		.about__grid {
			grid-template-columns: 1fr;
			justify-items: center;
			text-align: center;
		}
		.about__photo {
			margin: 0 auto;
		}
		.about__body {
			text-align: left;
			width: 100%;
		}
		.about__body h1,
		.about__role {
			text-align: center;
		}
		/* Justified text needs a wide-enough column to avoid rivers; a phone
		   column is not one. */
		.about__grid p {
			text-align: start;
		}
	}
</style>
