---
// About page. Long-form copy will grow during migration; Phase 1 ships a
// Bengali-first lede so the typography is reviewable.
import Base from '../layouts/Base.astro';
import Folio from '../components/Folio.astro';
import Masthead from '../components/Masthead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionHead from '../components/SectionHead.astro';
import SocialBar from '../components/SocialBar.astro';
import { BIO } from '../consts';
import { t } from '../utils/strings';
---

<Base title="About" lang="en">
	<Folio />
	<Masthead />
	<Nav />

	<main class="about" lang="en">
		<SectionHead label={t('about', 'en')} lang="en" />
		<div class="about__grid">
			<img class="about__photo" src={BIO.photo} width="220" height="220" alt={BIO.name} />
			<div>
				<h1>{BIO.name}</h1>
				<p class="about__role label">{BIO.role}</p>
				<p>
					I am Nahid Bin Azhar — a software engineer and co-founder of JoulesLabs.
					I have spent the last decade building software and the teams that ship it.
				</p>
				<p>
					Most of the writing here is in Bengali — engineering, business operations,
					productivity, and the occasional experiment. The aesthetic is old letterpress
					daily; the writing is contemporary.
				</p>
			</div>
		</div>

		<SectionHead label={t('elsewhere', 'en')} lang="en" />
		<SocialBar />
	</main>

	<Footer />
</Base>

<style>
	.about {
		margin-top: var(--sp-4);
	}
	.about__grid {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--sp-6);
		align-items: start;
		max-width: var(--sheet-max);
	}
	.about__photo {
		width: 220px;
		height: 220px;
		object-fit: cover;
		filter: grayscale(1) contrast(1.05);
		border: var(--rule-thin);
		background: var(--paper-shade);
	}
	.about__role {
		margin-top: 0;
	}
	.about__grid p {
		max-width: var(--measure);
		text-align: justify;
	}
	@media (max-width: 40rem) {
		.about__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
