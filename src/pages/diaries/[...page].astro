---
// Paginated diary archive: /diaries/ , /diaries/page/2/ … (§2, 10 per page).
import type { GetStaticPaths, PaginateFunction } from 'astro';
import Base from '../../layouts/Base.astro';
import Folio from '../../components/Folio.astro';
import Masthead from '../../components/Masthead.astro';
import Nav from '../../components/Nav.astro';
import SectionHead from '../../components/SectionHead.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import Footer from '../../components/Footer.astro';
import { PER_PAGE } from '../../consts';
import { getPublishedPosts } from '../../utils/posts';
import { t } from '../../utils/strings';

export const getStaticPaths = (async ({ paginate }: { paginate: PaginateFunction }) => {
	const posts = await getPublishedPosts();
	return paginate(posts, { pageSize: PER_PAGE });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Base title={t('allDiaries', 'en')} lang="en">
	<Folio />
	<Masthead />
	<Nav />

	<main>
		<SectionHead label={t('allDiaries', 'en')} lang="en" />
		<div class="archive">
			{page.data.map((post) => <PostCard post={post} />)}
		</div>
		<Pagination
			prevUrl={page.url.prev}
			nextUrl={page.url.next}
			current={page.currentPage}
			total={page.lastPage}
			lang="en"
		/>
	</main>

	<Footer />
</Base>

<style>
	.archive {
		display: grid;
		gap: 0;
	}
	.archive > :global(.card) {
		border-top: var(--rule-hair);
	}
	.archive > :global(.card:last-child) {
		border-bottom: var(--rule-hair);
	}
</style>
