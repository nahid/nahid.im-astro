---
// Home, assembled in the approved order (Phase 1 §5):
// Masthead → Nav → Bio → Achievements → Social → Recent posts → Footer.
import Base from '../layouts/Base.astro';
import Folio from '../components/Folio.astro';
import Masthead from '../components/Masthead.astro';
import Nav from '../components/Nav.astro';
import Bio from '../components/Bio.astro';
import Newsletter from '../components/Newsletter.astro';
import Achievements from '../components/Achievements.astro';
import SocialBar from '../components/SocialBar.astro';
import SectionHead from '../components/SectionHead.astro';
import PostCard from '../components/PostCard.astro';
import Footer from '../components/Footer.astro';
import { RECENT_COUNT } from '../consts';
import { getPublishedPosts } from '../utils/posts';
import { t } from '../utils/strings';

const recent = (await getPublishedPosts()).slice(0, RECENT_COUNT);
---

<Base lang="bn">
	<Folio />
	<Masthead />
	<Nav />

	<main>
		<div class="lede-grid">
			<Bio />
			<aside class="lede-grid__aside">
				<Newsletter />
			</aside>
		</div>

		<SectionHead label={t('achievements', 'bn')} lang="bn" />
		<Achievements />

		<SectionHead label={t('elsewhere', 'bn')} lang="bn" />
		<SocialBar />

		<SectionHead label={t('latestDispatches', 'bn')} lang="bn" href="/diaries/" />
		{
			recent.length > 0 ? (
				<div class="latest">
					{recent.map((post) => (
						<PostCard post={post} />
					))}
				</div>
			) : (
				<p class="meta" lang="bn">এখনো কোনো ডায়েরি প্রকাশিত হয়নি।</p>
			)
		}
	</main>

	<Footer />
</Base>

<style>
	.lede-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--sp-6);
		margin-top: var(--sp-6);
	}
	@media (min-width: 48rem) {
		.lede-grid {
			grid-template-columns: 2fr 1fr;
			align-items: start;
		}
		.lede-grid__aside {
			border-left: var(--rule-hair);
			padding-left: var(--sp-5);
		}
	}
	/* Column-ruled list of recent dispatches. */
	.latest {
		display: grid;
		gap: 0;
	}
	.latest > :global(.card) + :global(.card) {
		border-top: var(--rule-hair);
	}
	@media (min-width: 48rem) {
		.latest {
			grid-template-columns: 1fr 1fr;
			column-gap: var(--sp-6);
		}
		.latest > :global(.card) {
			border-top: var(--rule-hair);
		}
	}
</style>
