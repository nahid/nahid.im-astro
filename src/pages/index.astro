---
// Home, assembled in the approved order (Phase 1 §5):
// Masthead → Nav → Bio → Achievements → Social → Recent posts → Footer.
import Base from '../layouts/Base.astro';
import Folio from '../components/Folio.astro';
import Masthead from '../components/Masthead.astro';
import Nav from '../components/Nav.astro';
import Bio from '../components/Bio.astro';
import Newsletter from '../components/Newsletter.astro';
import Achievements from '../components/Achievements.astro';
import OpenSource from '../components/OpenSource.astro';
import SocialBar from '../components/SocialBar.astro';
import SectionHead from '../components/SectionHead.astro';
import PostCard from '../components/PostCard.astro';
import Footer from '../components/Footer.astro';
import { RECENT_COUNT, GITHUB_PROFILE } from '../consts';
import { getPublishedPosts } from '../utils/posts';
import { t } from '../utils/strings';

const recent = (await getPublishedPosts()).slice(0, RECENT_COUNT);
---

<Base lang="en" description={t('homeDesc', 'en')}>
	<Folio />
	<Masthead />
	<Nav />

	<main class="home">
		<div class="lede-grid">
			<Bio />
			<aside class="lede-grid__aside">
				<Newsletter />
			</aside>
		</div>

		<SectionHead label={t('achievements', 'en')} lang="en" />
		<Achievements />

		<SectionHead label={t('openSource', 'en')} lang="en" href={GITHUB_PROFILE} />
		<p class="home__lede">{t('openSourceLede', 'en')}</p>
		<OpenSource />

		<SectionHead label={t('elsewhere', 'en')} lang="en" />
		<SocialBar />

		<SectionHead label={t('latestDispatches', 'en')} lang="en" href="/diaries/" />
		{
			recent.length > 0 ? (
				<div class="latest">
					{recent.map((post) => (
						<PostCard post={post} />
					))}
				</div>
			) : (
				<p class="meta">The wire is quiet — no dispatches transmitted yet.</p>
			)
		}
	</main>

	<Footer />
</Base>

<style>
	.home {
		padding-top: var(--sp-5);
	}
	/* Sits under a section head as a short intro line (e.g. Open Source). */
	.home__lede {
		max-width: var(--measure);
		margin: 0 0 var(--sp-5);
		color: var(--faded);
	}
	.lede-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--sp-6);
	}
	@media (min-width: 48rem) {
		.lede-grid {
			grid-template-columns: 2fr 1fr;
			align-items: start;
		}
		.lede-grid__aside {
			border-left: var(--rule-hair);
			padding-left: var(--sp-5);
		}
	}
	/* Column-ruled list of recent dispatches. */
	.latest {
		display: grid;
		gap: 0;
	}
	.latest > :global(.card) {
		border-top: var(--rule-hair);
	}
	.latest > :global(.card:first-child) {
		border-top: none;
	}
	@media (min-width: 48rem) {
		.latest {
			grid-template-columns: 1fr 1fr;
			column-gap: var(--sp-6);
		}
		/* Second card sits in the first row on desktop's 2-col grid, so it
		   shouldn't get a top rule either — only .card:first-child would. */
		.latest > :global(.card:nth-child(2)) {
			border-top: none;
		}
	}
</style>
