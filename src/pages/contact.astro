---
// Contact page. No backend is run for this static site, so the "form" is a
// plain mailto: link — zero infra, zero client JS.
import Base from '../layouts/Base.astro';
import Folio from '../components/Folio.astro';
import Masthead from '../components/Masthead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionHead from '../components/SectionHead.astro';
import SocialBar from '../components/SocialBar.astro';
import { BIO, SITE } from '../consts';
import { t } from '../utils/strings';
---

<Base title="Contact" lang="en" description={t('contactDesc', 'en')}>
	<Folio />
	<Masthead />
	<Nav />

	<main id="main" class="contact" lang="en">
		<SectionHead label={t('contact', 'en')} lang="en" />
		<p class="contact__lede">
			Transmit a dispatch — every signal reaches the desk, and every signal is read.
		</p>

		<div class="contact__grid">
			<div class="letter">
				<p class="letter__kicker label">Wire Room</p>
				<p class="letter__quote">“All signals in, all signals read.”</p>
				<p class="letter__text">
					Skip the form — send the transmission straight to the desk. Every
					message gets a reply.
				</p>
				<a class="letter__btn" href={`mailto:${SITE.email}`}>{t('contactMailCta', 'en')}</a>
				<p class="letter__address meta">{SITE.email}</p>
			</div>

			<aside class="contact__aside">
				<p class="contact__aside-kicker label">Other Frequencies</p>
				<p class="contact__aside-text">
					For anything faster than a letter, the usual frequencies are open
					below.
				</p>
				<SocialBar />
				<p class="contact__aside-meta meta">
					Dispatched from {BIO.location} — an alien engineer, reading every wire
					personally.
				</p>
			</aside>
		</div>
	</main>

	<Footer />
</Base>

<style>
	.contact {
		max-width: var(--sheet-max);
	}
	.contact__lede {
		max-width: var(--measure);
	}
	.contact__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--sp-7);
		align-items: start;
		margin-top: var(--sp-5);
	}
	.letter {
		border: var(--rule-thin);
		padding: var(--sp-5);
	}
	.letter__kicker {
		margin: 0 0 var(--sp-2);
	}
	.letter__quote {
		font-family: var(--font-display);
		font-size: var(--fs-h3);
		line-height: 1.3;
		margin: 0 0 var(--sp-3);
		color: var(--accent);
	}
	.letter__text {
		margin: 0 0 var(--sp-4);
		color: var(--faded);
	}
	.letter__btn {
		display: inline-block;
		padding: var(--sp-2) var(--sp-5);
		font-family: var(--font-display);
		font-weight: 700;
		font-size: var(--fs-body);
		color: var(--paper);
		background: var(--ink);
		border: var(--rule-thin);
		text-decoration: none;
		transition: background-color 0.15s ease, border-color 0.15s ease;
	}
	.letter__btn:hover {
		background: var(--accent);
		border-color: var(--accent);
	}
	.letter__btn:focus-visible {
		outline: var(--focus-ring);
		outline-offset: 2px;
	}
	.letter__address {
		margin: var(--sp-3) 0 0;
		color: var(--faded);
	}
	.contact__aside {
		border-left: var(--rule-hair);
		padding-left: var(--sp-5);
	}
	.contact__aside-kicker {
		margin: 0 0 var(--sp-2);
	}
	.contact__aside-text {
		margin: 0 0 var(--sp-4);
		color: var(--faded);
	}
	.contact__aside-meta {
		margin: var(--sp-4) 0 0;
		padding-top: var(--sp-3);
		border-top: var(--rule-hair);
	}
	@media (max-width: 48rem) {
		.contact__grid {
			grid-template-columns: 1fr;
		}
		.contact__aside {
			border-left: none;
			padding-left: 0;
			padding-top: var(--sp-5);
			border-top: var(--rule-hair);
		}
	}
</style>
